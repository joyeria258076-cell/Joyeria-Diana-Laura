{
  "name": "diana-laura-backend",
  "version": "1.0.0",
  "type": "commonjs",
  "scripts": {
    "dev": "nodemon --ignore iast-reports/ --ignore backups_automaticos/ --ignore rasp-reports/ --ignore *.log --exitcrash --signal SIGTERM --legacy-watch --exec ts-node src/server.ts",
    "dev:no-restart": "nodemon --ignore iast-reports/ --ignore backups_automaticos/ --ignore rasp-reports/ --ignore *.log --exitcrash --signal SIGTERM --legacy-watch --exec ts-node src/server.ts",
    "start": "node dist/server.js",
    "build": "tsc",
    "test-db": "ts-node src/scripts/test-railway.ts",
    "railway-setup": "npm run build && npm start",
    "audit:fix": "npm audit fix",
    "audit:force": "npm audit fix --force",
    "security:check": "npm audit --audit-level=high"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.95.3",
    "@types/jsonwebtoken": "^9.0.10",
    "axios": "^1.13.2",
    "bcryptjs": "^2.4.3",
    "cloudinary": "^2.9.0",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "csv-parser": "^3.2.0",
    "dd-trace": "^5.92.0",
    "dotenv": "^16.3.1",
    "exceljs": "^4.4.0",
    "express": "^4.18.2",
    "express-rate-limit": "^8.3.2",
    "firebase-admin": "^13.5.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "multer": "^2.1.1",
    "newrelic": "^13.17.0",
    "node-cron": "^4.2.1",
    "nodemailer": "^7.0.10",
    "pg": "^8.16.3",
    "qrcode": "^1.5.4",
    "react-icons": "^5.5.0",
    "resend": "^6.4.2",
    "sib-api-v3-sdk": "^8.5.0",
    "speakeasy": "^2.0.0",
    "streamifier": "^0.1.1",
    "xss": "^1.0.15",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-rate-limit": "^5.1.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^20.19.35",
    "@types/node-cron": "^3.0.11",
    "@types/nodemailer": "^7.0.3",
    "@types/pg": "^8.11.2",
    "@types/qrcode": "^1.5.5",
    "@types/speakeasy": "^2.0.10",
    "@types/streamifier": "^0.1.2",
    "nodemon": "^3.1.7",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "overrides": {
    "node-forge": "^1.3.2"
  },
  "resolutions": {
    "node-forge": "^1.3.2"
  }
}